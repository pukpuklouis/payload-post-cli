{
  "name": "@anlstudio/payload-post-cli",
  "version": "0.1.0",
  "type": "module",
  "types": "./dist/types/index.d.ts",
  "bin": {
    "payload-post": "./bin/payload-post"
  },
  "description": "Terminal-native CLI for managing Payload CMS posts.",
  "files": [
    "dist",
    "bin/payload-post",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli/entry.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm test",
    "prepack": "npm run check && npm run build",
    "start": "node dist/cli/entry.js",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^7.0.2",
    "react": "^19.2.6",
    "tsx": "^4.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
